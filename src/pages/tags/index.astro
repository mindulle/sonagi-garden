---
import BaseLayout from '../../layouts/Base.astro';
import { Card } from '../../components/ui';

// 모든 마크다운 파일에서 태그 추출
const allNotes = await Astro.glob('../../../content/**/*.md');

// 태그별 노트 개수 집계
const tagMap = new Map<string, number>();

allNotes.forEach((note) => {
  const tags = note.frontmatter?.tags || [];
  tags.forEach((tag: string) => {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  });
});

// 태그를 배열로 변환하고 인기순(노트 개수)으로 정렬
const tags = Array.from(tagMap.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);
---

<BaseLayout title="Tags" description="Browse all tags">
  <div class="tags-page">
    <div class="tags-container">
      <header class="tags-header">
        <h1>모든 태그</h1>
        <p class="subtitle">{tags.length}개의 태그로 {allNotes.length}개의 노트를 탐색하세요</p>
      </header>

      <div class="tags-grid">
        {tags.map((tag) => (
          <a href={`/tags/${tag.name}`} class="tag-link">
            <Card variant="default" client:load>
              <div class="tag-card">
                <span class="tag-name">#{tag.name}</span>
                <span class="tag-count">{tag.count}개의 노트</span>
              </div>
            </Card>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .tags-page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--sonagi-spacing-lg);
  }

  .tags-container {
    padding: var(--sonagi-spacing-2xl) 0;
  }

  .tags-header {
    margin-bottom: var(--sonagi-spacing-2xl);
  }

  .tags-header h1 {
    font-size: var(--sonagi-font-size-3xl);
    color: var(--sonagi-color-text-primary);
    margin-bottom: var(--sonagi-spacing-sm);
  }

  .subtitle {
    font-size: var(--sonagi-font-size-md);
    color: var(--sonagi-color-text-secondary);
  }

  .tags-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: var(--sonagi-spacing-lg);
  }

  .tag-link {
    text-decoration: none;
    transition: transform var(--sonagi-transition-fast);
  }

  .tag-link:hover {
    transform: translateY(-4px);
  }

  .tag-card {
    padding: var(--sonagi-spacing-lg);
    display: flex;
    flex-direction: column;
    gap: var(--sonagi-spacing-sm);
  }

  .tag-name {
    font-size: var(--sonagi-font-size-xl);
    font-weight: 600;
    color: var(--sonagi-color-primary);
  }

  .tag-count {
    font-size: var(--sonagi-font-size-sm);
    color: var(--sonagi-color-text-secondary);
  }

  @media (max-width: 768px) {
    .tags-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
