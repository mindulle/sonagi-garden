---
import BaseLayout from '@/layouts/Base.astro';

const designNotes = await Astro.glob('../../content/design/*.md');

const sortedNotes = designNotes.sort((a, b) => {
  const dateA = new Date(a.frontmatter.date || 0);
  const dateB = new Date(b.frontmatter.date || 0);
  return dateB.getTime() - dateA.getTime();
});

const getSlug = (filePath: string) => {
  return filePath
    .replace(/^.*\/content\//, '')
    .replace(/\.md$/, '');
};

const formatDate = (dateString: string) => {
  if (!dateString) return '';
  const date = new Date(dateString);
  return date.toLocaleDateString('ko-KR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<BaseLayout 
  title="Design" 
  description="디자인, UX/UI, 크리에이티브 관련 노트"
>
  <div class="domain-page">
    <div class="domain-header">
      <div class="domain-icon">🎨</div>
      <h1 class="domain-title">Design</h1>
      <p class="domain-description">
        디자인, UX/UI, 크리에이티브 관련 노트들을 모았습니다.
      </p>
    </div>
    
    <div class="notes-list">
      {sortedNotes.length === 0 ? (
        <div class="empty-state">
          <p>아직 노트가 없습니다. 첫 노트를 작성해보세요! 📝</p>
        </div>
      ) : (
        sortedNotes.map(note => {
          const { title, date, tags = [], description } = note.frontmatter;
          const slug = getSlug(note.file);
          
          return (
            <article class="note-card">
              <a href={`/${slug}`} class="note-card-link">
                <h2 class="note-card-title">{title || 'Untitled'}</h2>
                
                {description && (
                  <p class="note-card-description">{description}</p>
                )}
                
                <div class="note-card-meta">
                  {date && (
                    <time class="note-card-date" datetime={date}>
                      {formatDate(date)}
                    </time>
                  )}
                  
                  {tags.length > 0 && (
                    <div class="note-card-tags">
                      {tags.map((tag: string) => (
                        <span class="tag">#{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            </article>
          );
        })
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .domain-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--sonagi-spacing-lg);
  }
  
  .domain-header {
    text-align: center;
    margin-bottom: var(--sonagi-spacing-2xl);
    padding-bottom: var(--sonagi-spacing-2xl);
    border-bottom: 2px solid var(--sonagi-color-border);
  }
  
  .domain-icon {
    font-size: 4rem;
    margin-bottom: var(--sonagi-spacing-md);
  }
  
  .domain-title {
    font-size: var(--sonagi-font-size-3xl);
    color: var(--sonagi-color-primary);
    margin-bottom: var(--sonagi-spacing-md);
  }
  
  .domain-description {
    font-size: var(--sonagi-font-size-lg);
    color: var(--sonagi-color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }
  
  .notes-list {
    display: grid;
    gap: var(--sonagi-spacing-xl);
  }
  
  .empty-state {
    text-align: center;
    padding: var(--sonagi-spacing-2xl);
    color: var(--sonagi-color-text-secondary);
    font-size: var(--sonagi-font-size-lg);
  }
  
  .note-card {
    background: white;
    border: 1px solid var(--sonagi-color-border);
    border-radius: var(--sonagi-radius-lg);
    overflow: hidden;
    transition: all var(--sonagi-transition-base);
  }
  
  .note-card:hover {
    border-color: var(--sonagi-color-primary);
    transform: translateY(-4px);
    box-shadow: var(--sonagi-shadow-lg);
  }
  
  .note-card-link {
    display: block;
    padding: var(--sonagi-spacing-xl);
    color: inherit;
    text-decoration: none;
  }
  
  .note-card-title {
    font-size: var(--sonagi-font-size-xl);
    color: var(--sonagi-color-text-primary);
    margin-bottom: var(--sonagi-spacing-md);
    transition: color var(--sonagi-transition-fast);
  }
  
  .note-card:hover .note-card-title {
    color: var(--sonagi-color-primary);
  }
  
  .note-card-description {
    color: var(--sonagi-color-text-secondary);
    margin-bottom: var(--sonagi-spacing-md);
    line-height: 1.6;
  }
  
  .note-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sonagi-spacing-md);
    align-items: center;
    font-size: var(--sonagi-font-size-sm);
    color: var(--sonagi-color-text-secondary);
  }
  
  .note-card-date {
    display: flex;
    align-items: center;
  }
  
  .note-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sonagi-spacing-xs);
  }
  
  .tag {
    padding: var(--sonagi-spacing-xs) var(--sonagi-spacing-sm);
    background: var(--sonagi-color-surface);
    border-radius: var(--sonagi-radius-sm);
    font-size: var(--sonagi-font-size-xs);
  }
  
  @media (max-width: 768px) {
    .domain-icon {
      font-size: 3rem;
    }
    
    .domain-title {
      font-size: var(--sonagi-font-size-2xl);
    }
    
    .note-card-link {
      padding: var(--sonagi-spacing-lg);
    }
  }
</style>
