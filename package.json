{
  "name": "sonagi-garden",
  "type": "module",
  "version": "0.1.0",
  "description": "청량한 디지털 정원 - Astro와 Sonagi 디자인 시스템 기반",
  "scripts": {
    "dev": "pnpm generate:backlinks && astro dev",
    "start": "astro dev",
    "generate:backlinks": "node scripts/generate-backlinks.mjs",
    "generate:graph": "node scripts/generate-graph-data.mjs",
    "build": "pnpm generate:backlinks && pnpm generate:graph && astro build && npx pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "migrate": "node scripts/migrate-notes.js"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^3.6.2",
    "@astrojs/rss": "^4.0.14",
    "@astrojs/sitemap": "^3.6.0",
    "@giscus/react": "^3.1.0",
    "astro": "^4.16.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.29.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-wiki-link": "^2.0.1",
    "shiki": "^1.27.0",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "glob": "^13.0.0",
    "gray-matter": "^4.0.3",
    "pagefind": "^1.4.0"
  }
}